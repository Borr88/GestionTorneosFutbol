<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="clasificacion" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="fd4fb6f3-36a0-4366-834f-3cdd3e0efcbc">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion_SQLite_Torneo"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<subDataset name="DatasetEstadisticas" uuid="7dda8295-3809-491d-922d-5d8c35ef474c">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion_SQLite_Torneo"/>
		<parameter name="FASE" class="java.lang.String"/>
		<queryString language="SQL"><![CDATA[SELECT 
    (SELECT IFNULL(SUM(goles_local + goles_visitante), 0) 
     FROM partidos 
     WHERE ($P{FASE} IS NULL OR fase = $P{FASE}) AND finalizado = 1) AS total_goles,

    (SELECT IFNULL(ROUND(AVG(goles_local + goles_visitante), 2), 0) 
     FROM partidos 
     WHERE ($P{FASE} IS NULL OR fase = $P{FASE}) AND finalizado = 1) AS promedio_goles,

    (SELECT IFNULL(SUM(e.amarillas), 0) 
     FROM estadisticas e 
     INNER JOIN partidos p ON e.partido_id = p.id 
     WHERE ($P{FASE} IS NULL OR p.fase = $P{FASE}) AND p.finalizado = 1) AS total_amarillas,

    (SELECT IFNULL(SUM(e.rojas), 0) 
     FROM estadisticas e 
     INNER JOIN partidos p ON e.partido_id = p.id 
     WHERE ($P{FASE} IS NULL OR p.fase = $P{FASE}) AND p.finalizado = 1) AS total_rojas]]></queryString>
		<field name="total_goles" class="java.lang.Integer"/>
		<field name="promedio_goles" class="java.lang.Integer"/>
		<field name="total_amarillas" class="java.lang.Integer"/>
		<field name="total_rojas" class="java.lang.Integer"/>
	</subDataset>
	<subDataset name="DatasetRendimiento" uuid="885734c8-46d7-4fa6-b206-b1391bc77dd2">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion_SQLite_Torneo"/>
		<parameter name="FASE" class="java.lang.String"/>
		<queryString language="SQL"><![CDATA[SELECT 
    IFNULL((SELECT equipo FROM (SELECT el.nombre AS equipo, COUNT(*) as victorias FROM partidos p JOIN equipos el ON p.equipo_local_id = el.id WHERE p.finalizado = 1 AND p.goles_local > p.goles_visitante AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY el.id UNION ALL SELECT ev.nombre AS equipo, COUNT(*) as victorias FROM partidos p JOIN equipos ev ON p.equipo_visitante_id = ev.id WHERE p.finalizado = 1 AND p.goles_visitante > p.goles_local AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY ev.id) GROUP BY equipo ORDER BY SUM(victorias) DESC LIMIT 1), 'N/A') AS mas_victorias,
    IFNULL((SELECT equipo FROM (SELECT el.nombre AS equipo, SUM(p.goles_local) as goles FROM partidos p JOIN equipos el ON p.equipo_local_id = el.id WHERE p.finalizado = 1 AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY el.id UNION ALL SELECT ev.nombre AS equipo, SUM(p.goles_visitante) as goles FROM partidos p JOIN equipos ev ON p.equipo_visitante_id = ev.id WHERE p.finalizado = 1 AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY ev.id) GROUP BY equipo ORDER BY SUM(goles) DESC LIMIT 1), 'N/A') AS mas_goles,
    IFNULL((SELECT equipo FROM (SELECT el.nombre AS equipo, SUM(p.goles_visitante) as goles_recibidos FROM partidos p JOIN equipos el ON p.equipo_local_id = el.id WHERE p.finalizado = 1 AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY el.id UNION ALL SELECT ev.nombre AS equipo, SUM(p.goles_local) as goles_recibidos FROM partidos p JOIN equipos ev ON p.equipo_visitante_id = ev.id WHERE p.finalizado = 1 AND ($P{FASE} IS NULL OR p.fase = $P{FASE}) GROUP BY ev.id) GROUP BY equipo ORDER BY SUM(goles_recibidos) ASC LIMIT 1), 'N/A') AS menos_goles]]></queryString>
		<field name="mas_victorias" class="java.lang.String"/>
		<field name="mas_goles" class="java.lang.String"/>
		<field name="menos_goles" class="java.lang.String"/>
	</subDataset>
	<parameter name="FASE" class="java.lang.String"/>
	<queryString language="SQL"><![CDATA[SELECT 
    fase,
    equipo,
    escudo,
    estado
FROM (
    SELECT 
        p.fase,
        el.nombre AS equipo,
        el.escudo_path AS escudo,
        CASE WHEN p.goles_local > p.goles_visitante THEN 'CLASIFICADO' ELSE 'ELIMINADO' END AS estado
    FROM partidos p
    INNER JOIN equipos el ON p.equipo_local_id = el.id
    WHERE ($P{FASE} IS NULL OR p.fase = $P{FASE}) AND p.finalizado = 1
    
    UNION ALL
    
    SELECT 
        p.fase,
        ev.nombre AS equipo,
        ev.escudo_path AS escudo,
        CASE WHEN p.goles_visitante > p.goles_local THEN 'CLASIFICADO' ELSE 'ELIMINADO' END AS estado
    FROM partidos p
    INNER JOIN equipos ev ON p.equipo_visitante_id = ev.id
    WHERE ($P{FASE} IS NULL OR p.fase = $P{FASE}) AND p.finalizado = 1
)
ORDER BY 
    CASE fase 
        WHEN 'Octavos' THEN 1 
        WHEN 'Cuartos' THEN 2 
        WHEN 'Semifinal' THEN 3 
        WHEN 'Final' THEN 4 
        ELSE 5 
    END,
    estado ASC,
    equipo ASC]]></queryString>
	<field name="fase" class="java.lang.String"/>
	<field name="equipo" class="java.lang.String"/>
	<field name="escudo" class="java.lang.String"/>
	<field name="estado" class="java.lang.String"/>

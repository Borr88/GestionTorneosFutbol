<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="equipos_jugadores" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="00000000-0000-0000-0000-000000000000">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion_SQLite_Torneo"/>
    <parameter name="ID_EQUIPO" class="java.lang.Integer"/>
    <queryString language="SQL"><![CDATA[SELECT
    e.id AS id_equipo,
    e.nombre AS nombre_equipo,
    e.escudo_path AS escudo_path,
    p.id AS id_jugador,
    p.nombre AS nombre_jugador,
    p.apellido AS apellido_jugador,
    p.posicion AS posicion,
    COALESCE(SUM(est.goles), 0) AS goles,
    COALESCE(SUM(est.amarillas), 0) AS amarillas,
    COALESCE(SUM(est.rojas), 0) AS rojas
FROM
    equipos e
LEFT JOIN
    participantes p ON e.id = p.equipo_id AND p.es_jugador = 1
LEFT JOIN
    estadisticas est ON p.id = est.participante_id
WHERE
    p.es_jugador = 1
    AND ($P{ID_EQUIPO} IS NULL OR e.id = $P{ID_EQUIPO})
GROUP BY
    e.id, p.id, p.nombre, p.apellido, p.posicion
ORDER BY
    e.nombre ASC, p.apellido ASC, p.nombre ASC]]></queryString>

    <field name="id_equipo" class="java.lang.Integer"/>
    <field name="nombre_equipo" class="java.lang.String"/>
    <field name="escudo_path" class="java.lang.String"/>
    <field name="id_jugador" class="java.lang.Integer"/>
    <field name="nombre_jugador" class="java.lang.String"/>
    <field name="apellido_jugador" class="java.lang.String"/>
    <field name="posicion" class="java.lang.String"/>
    <field name="goles" class="java.lang.Integer"/>
    <field name="amarillas" class="java.lang.Integer"/>
    <field name="rojas" class="java.lang.Integer"/>

    <variable name="TotalGoles" class="java.lang.Integer" resetType="Group" resetGroup="GrupoEquipo" calculation="Sum">
        <variableExpression><![CDATA[$F{goles}]]></variableExpression>
    </variable>
    <variable name="TotalAmarillas" class="java.lang.Integer" resetType="Group" resetGroup="GrupoEquipo" calculation="Sum">
        <variableExpression><![CDATA[$F{amarillas}]]></variableExpression>
    </variable>
    <variable name="TotalRojas" class="java.lang.Integer" resetType="Group" resetGroup="GrupoEquipo" calculation="Sum">
        <variableExpression><![CDATA[$F{rojas}]]></variableExpression>
    </variable>

    <group name="GrupoEquipo">
